; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LOTTH RPG"
config/tags=PackedStringArray("lotth", "medium_sized_project", "testing", "unfinished")
run/main_scene="uid://cnj4khiyopq7m"
config/custom_user_dir_name="LOTTH_RPG_Mechanic"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

video/autoload_on_startup=true

[autoload]

procam="*res://addons/ProCam2D/scripts/autoload.gd"
Data="*res://scripts/data/data.gd"
Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
AlwaysOn="*res://scripts/gd/always_on.gd"

[dialogic]

directories/dch_directory={
"Alex": "res://scripts/resources/Text_Box/Alex.dch"
}
directories/dtl_directory={
"a_speaker": "res://scripts/resources/Text_Box/a_speaker.dtl",
"act_Ball": "res://scripts/resources/Text_Box/act_Ball.dtl",
"act_Check": "res://scripts/resources/Text_Box/act_Check.dtl",
"act_Grab": "res://scripts/resources/Text_Box/act_Grab.dtl",
"act_Sleep": "res://scripts/resources/Text_Box/act_Sleep.dtl",
"act_Talk": "res://scripts/resources/Text_Box/act_Talk.dtl",
"act_Twirl": "res://scripts/resources/Text_Box/act_Twirl.dtl",
"act_focus": "res://scripts/resources/Text_Box/act_Focus.dtl",
"stat_baller": "res://scripts/resources/Text_Box/stat_baller.dtl",
"static_textbox_handler": "res://scripts/resources/Text_Box/static_textbox_handler.dtl"
}
layout/style_directory={
"": "res://scripts/resources/Text_Box/Speak_Bubble.tres",
"Boxless_Textbox": "res://scripts/resources/Text_Box/Boxless_Textbox.tres",
"Normal_Textbox": "res://scripts/resources/Text_Box/Normal_Textbox.tres",
"Profile_Tectboc": "res://scripts/resources/Text_Box/Profile_Tectboc.tres",
"Speak_Bubble": "res://scripts/resources/Text_Box/Speak_Bubble.tres"
}
layout/style_list=["res://scripts/resources/Text_Box/Profile_Tectboc.tres", "res://scripts/resources/Text_Box/Normal_Textbox.tres", "res://scripts/resources/Text_Box/Boxless_Textbox.tres", "res://scripts/resources/Text_Box/Speak_Bubble.tres"]
layout/default_style="res://scripts/resources/Text_Box/Speak_Bubble.tres"
glossary/default_case_sensitive=true
variables={
"Base_Magical_Attack": 0,
"Base_Phisical_Attack": 0,
"Defense": 0,
"EMP": 0,
"MAX_EMP": 0,
"Magic_Defense": 0,
"name": "",
"your_name": "Alex"
}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
text/input_action="dialogic_default_action"

[display]

window/size/viewport_width=1640
window/size/viewport_height=840
window/size/always_on_top=true
window/size/window_width_override=1230
window/size/window_height_override=630
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[editor]

version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/ProCam2D/plugin.cfg", "res://addons/dialogic/plugin.cfg")

[file_customization]

folder_colors={
"res://Objects_scripts_and_scenes/": "green",
"res://addons/": "gray",
"res://assets/": "purple",
"res://assets/sprite/": "pink",
"res://reworking_mechanics/": "gray",
"res://scenes/": "red",
"res://scripts/": "yellow",
"res://scripts/gd/": "orange",
"res://scripts/gdshader/": "teal",
"res://scripts/resources/": "blue"
}

[global_group]

Player=""
Enemy=""
Ignoreable=""

[gui]

theme/custom="res://scripts/resources/misaliniouse/UI_theme.tres"

